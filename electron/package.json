{
  "name": "xianmiao",
  "version": "1.0.0",
  "description": "闲妙 - AI驱动的二手闲置交易平台",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.xianmiao.app",
    "productName": "闲妙",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "../.next/**/*",
      "../public/**/*",
      "../package.json",
      "../node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.shopping",
      "icon": "../public/icons/icon-512.png",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "../public/icons/icon-512.png",
      "target": ["nsis", "zip"]
    },
    "linux": {
      "icon": "../public/icons/icon-512.png",
      "target": ["AppImage", "deb"]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
